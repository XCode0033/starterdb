<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Dream <%= dream.id %></title>
</head>
<body>
    <h1>Edit Dream: <%= dream.id%>, <%= dream.title %></h1>

    <form id="updateForm" action="/<%= dream.id%>" method="POST">
        <div>
        <label for="title">Title</label>
        <input type="text" name="title" value="<%= dream.title%>">
        </div>
        <div>
            <label for="dream_date">Date</label>
            <input type="text "name="dream_date" value="<%=dream.dream_date%>">
        </div>
        <div>
            <label for="stars">Stars</label>
            <input type="text" name="stars" value="<%= dream.stars%>">
        </div>
        <div>
            <label for="description">Description</label>
            <input type="text" name="description" value="<%= dream.description%>">
        </div>
        <a href="/">Back to Homepage</a>
        <button type="submit">Submit Edit</button>

    </form>


    <script>
        const form = document.getElementById('updateForm')

        form.addEventListener("submit", async (event) => {
            event.preventDefault();

            const formData = new FormData(form)

            const updatedDream = {
                title: formData.get("title"),
                stars: formData.get("stars"),
                dream_date: formData.get("dream_date"),
                description: formData.get("description")
            }

            const result = await fetch("/<%= dream.id %>", {
                method:"PATCH",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify(updatedDream)
            })
        })
    </script>
</body>
</html>