<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dream Homepage</title>
    <style>
        #deleteBtn {
            margin-top: 10px;
        }
        #top-section {
            display: flex;
        }
    </style>
</head>
<body>
    <h1>All Dreams</h1>
    <% 
    function buildUrl(overrides = {}) {
        const params = new URLSearchParams();

        const merged = {
            dream_id: filters?.dream_id || "",
            title: filters?.title || "",
            dream_date: filters?.dream_date || "",
            stars: filters?.stars || "",
            description: filters?.description || "",
            tag_id: filters?.tag_id || "",
            tag_name: filters?.tag_name || "",
            sortBy: filters?.sortBy || "dream_id",
            sortDir: filters?.sortDir || "desc",
            ...overrides
        }

        Object.entries(merged).forEach(([key, value]) => {
    if (value !== "" && value !== null && value !== undefined) {
        params.set(key, String(value));
    }
});

        return `/?${params.toString()}`;
    }
    %>
<div id="top-section">
    <div id="create-section">
        <h2>Create Dream</h2>
        <form id="createDream" action="/" method="POST">
            <input type="text" name="title" placeholder="Title">
            <input type="text" name="dream_date" placeholder="Date">
            <input type="text" name="stars" placeholder="Stars">
            <input type="text" name="description" placeholder="Description">
            <input type="text" name="tag_name" placeholder="Tag Name">
            <button type="submit">Create Dream</button>
        </form>

    </div>
    <div id="search-section">
        <h2>Search</h2>
        <form id="searchForm" action="/" method="GET">
            <input type="text" name="title" value="<%= filters?.title || ""%>" placeholder="Title">
            <input type="text" name="dream_date" value="<%= filters?.dream_date || "" %>" placeholder="Date">
            <input type="text" name="stars" value="<%= filters?.stars || "" %>" placeholder="Stars">
            <input type="text" name="description" value="<%= filters?.description || "" %>" placeholder="Description">
            <input type="text" name="tag_name" value="<%= filters?.tag_name || "" %>" placeholder="Tag Name">
            
            <input type="hidden" name="sortBy" value="<%= filters?.sortBy || 'dream_id'%>">
            <input type="hidden" name="sortDir" value="<%= filters?.sortDir || 'desc'%>">
            
            <button type="submit">Search</button>
            <a href="/">Reset</a>
        </form>
    </div>
</div>
<div id="sort-section">
    <h2>Sort</h2>

    <a href="<%= buildUrl({ sortBy: 'dream_id', sortDir: 'desc' }) %>">Newest</a>
    <a href="<%= buildUrl({ sortBy: 'dream_id', sortDir: 'asc' }) %>">Oldest</a>

    <a href="<%= buildUrl({ sortBy: 'title', sortDir: 'asc' }) %>">Title A-Z</a>
    <a href="<%= buildUrl({ sortBy: 'title', sortDir: 'desc' }) %>">Title Z-A</a>

    <a href="<%= buildUrl({ sortBy: 'dream_date', sortDir: 'desc' }) %>">Newest Date</a>
    <a href="<%= buildUrl({ sortBy: 'dream_date', sortDir: 'asc' }) %>">Oldest Date</a>

    <a href="<%= buildUrl({ sortBy: 'stars', sortDir: 'desc' }) %>">Highest Stars</a>
    <a href="<%= buildUrl({ sortBy: 'stars', sortDir: 'asc' }) %>">Lowest Stars</a>

    <a href="<%= buildUrl({ sortBy: 'tag_name', sortDir: 'asc' }) %>">Tag A-Z</a>
    <a href="<%= buildUrl({ sortBy: 'tag_name', sortDir: 'desc' }) %>">Tag Z-A</a>
</div>
<p>
    Sorting by: <%= filters?.sortBy || 'dream_id' %>
    (<%= filters?.sortDir || 'desc' %>)
</p>

<div id="results-section">
    <h2>Dream Results</h2>

    <% if (dreams && dreams.length > 0) { %>
        <% dreams.forEach(dream => { %>
            <div class="dream-card">
                <h3><%= dream.title || 'Untitled' %></h3>
                <p>Dream ID: <%= dream.dream_id %></p>
                <p>Date: <%= dream.dream_date %></p>
                <p>Stars: <%= dream.stars %></p>
                <p>Description: <%= dream.description || 'No description' %></p>
                <p>Tag: <%= dream.tag_name || 'None' %></p>
                <a href="/<%= dream.dream_id %>/editPage">Edit Dream</a>
                <form class="deleteForms"  data-id="<%= dream.dream_id%>" action="/<%=dream.dream_id%>" method="DELETE">
                <button id="deleteBtn" type="submit">Delete12</button>
                </form>
            <p>---------------</p>
            </div>
        <% }) %>
    <% } else { %>
        <p>No dreams found.</p>
    <% } %>
</div>



<!-- check claude to fix -->
        <script>
            
            //get form from dom
            const form = document.getElementById("createDream");

            form.addEventListener("submit", async(event) => {
                event.preventDefault;

                const formData = new FormData(form)

                const createdDream = {
                    title: formData.get("title"),
                    stars: formData.get("stars"),
                    dream_date: formData.get("dream_date"),
                    description: formData.get("description"),
                    tag_name: formData.get("tag_name")
                }

                const response = await fetch('/', {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    }
                })

                if(response.ok) {
                    window.location.reload();
                }


            })
            

            const deleteForms = document.querySelectorAll(".deleteForms");

            deleteForms.forEach(deleteForm => {
                deleteForm.addEventListener("submit", async(e) => {
                    e.preventDefault();

                    const form = e.currentTarget;
                    const id = deleteForm.dataset.id;

                   await fetch(`/${id}`, {
                        method:"DELETE"
                    })

                    window.location.reload();
                })
            });
            
            
        </script>
</body>
</html>